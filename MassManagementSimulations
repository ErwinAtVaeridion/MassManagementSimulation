# -----------------------------
# Monte‑Carlo engine
# -----------------------------
def run_monte_carlo(params_list, n_samples=N_SAMPLES):
    """Sum of sampled masses across a list of PERT parameter sets."""
    if not params_list:
        return np.array([])
    samples = [sample_pert(p, n_samples) for p in params_list]
    arr = np.vstack(samples)
    return arr.sum(axis=0)

# -----------------------------
# PERT Component PDF Plotting (Restored from original code)
# -----------------------------
def plot_component_pdfs(components, pert_params, plot_name="Input Components"):
    """
    Restored multi‑subplot PERT PDF plotting exactly like the original:
    - 2 columns
    - shaded PDFs
    - min/max markers
    - mode (predicted_mass) line
    - titles and grid
    - saved to PNG
    """
    n = len(components)
    if n == 0:
        return

    ncols = 2
    nrows = int(np.ceil(n / ncols))

    # Reduce height by 10% to avoid spilling into PDF footer
    fig_height = 3.5 * nrows * 0.90
    fig, axes = plt.subplots(nrows, ncols, figsize=(12, fig_height), squeeze=False)

    for idx, (name, t, d, u) in enumerate(components):
        r = idx // ncols
        c = idx % ncols
        ax = axes[r][c]

        params_idx = pert_params[idx]

        if params_idx[0] is None:
            # Fixed-value vertical line
            ax.axvline(t, color="k", linestyle="--", label=f"{name} (fixed)")
            ax.plot(t, 1.0, marker="v", color="k")  # small spike marker (arbitrary y)
            ax.set_ylim(0, 1.05)
            ax.text(t, 1.0, f"{t:.1f}", ha="center", va="bottom", fontsize=8)
        else:
            a, b, alpha, beta_param, m = params_idx
            # Build a PERT-like PDF using scipy's beta if available
            xs = np.linspace(a, b, 400)

            from scipy.stats import beta
            pdf_values = beta.pdf((xs - a) / (b - a), alpha, beta_param) / (b - a)

            ax.plot(xs, pdf_values, label=name)
            ax.fill_between(xs, pdf_values, alpha=0.15)

            # Min/max markers
            ax.plot(a, 0, marker="o", color="red", markersize=5)
            ax.text(a, 0, f"{a:.1f}", ha="right", va="bottom", fontsize=8)
            ax.plot(b, 0, marker="o", color="red", markersize=5)
            ax.text(b, 0, f"{b:.1f}", ha="left", va="bottom", fontsize=8)

            # Mode / Predicted Mass
            ax.axvline(t, color="k", linestyle=":", lw=1.5, label=f"Predicted: {t:.1f}")
            ax.text(t, ax.get_ylim()[1]*0.95, f"{t:.1f}",
                    ha="center", va="top", fontsize=8, color="k")

        ax.set_title(name)
        ax.set_xlabel("Mass [kg]")
        ax.set_ylabel("Density")
        ax.grid(True, alpha=0.25)
        ax.legend(loc="upper right", fontsize="small")

    # Hide extra empty axes
    total_subplots = nrows * ncols
    for idx in range(n, total_subplots):
        r = idx // ncols
        c = idx % ncols
        axes[r][c].axis("off")

    plt.suptitle(plot_name)
    plt.tight_layout(rect=[0, 0, 1, 0.98])
    fname = sanitize_filename(plot_name) + ".png"
    plt.savefig(fname, dpi=300)
    plt.close()

# -----------------------------
# L1B Group Monte-Carlo Plots (PDF & CDF)
# -----------------------------
def plot_monte_carlo_pdf(samples, title):
    if samples.size == 0:
        return

    plt.figure(figsize=(10, 6))

    # Detect deterministic distribution (zero variance)
    if np.var(samples) == 0:
        val = float(samples[0])
        plt.axvline(val, color="red", linestyle="--", lw=2, label=f"Deterministic mass = {val:.1f} kg")
        plt.title(title + " (Deterministic distribution)")
        plt.xlabel("Mass [kg]")
        plt.ylabel("Density")
        plt.legend()
        plt.grid(True, alpha=0.3)
        plt.tight_layout()
        plt.savefig(sanitize_filename(title) + ".png", dpi=300)
        plt.close()
        return

    # Normal case (non-zero variance)
    plt.hist(samples, bins=200, density=True, alpha=0.5, label="Histogram")

    kde = _scipy_gaussian_kde(samples)
    xs = np.linspace(samples.min(), samples.max(), 400)
    plt.plot(xs, kde(xs), "r-", lw=2, label="KDE")
    plt.title(title)
    plt.xlabel("Mass [kg]")
    plt.ylabel("Density")
    plt.legend()
    plt.grid(True, alpha=0.3)
    plt.tight_layout()
    plt.savefig(sanitize_filename(title) + ".png", dpi=300)
    plt.close()

def plot_monte_carlo_cdf(samples, title):
    if samples.size == 0:
        return

    sorted_samples = np.sort(samples)

    # If deterministic: CDF is a vertical jump at the single mass value
    if np.var(samples) == 0:
        val = float(sorted_samples[0])
        plt.figure(figsize=(10, 6))
        plt.plot([val, val], [0, 1], "r-", lw=2, label=f"Deterministic mass = {val:.1f} kg")
        plt.title(title + " (Deterministic distribution)")
        plt.xlabel("Mass [kg]")
        plt.ylabel("Cumulative probability")
        plt.grid(True, alpha=0.3)
        plt.tight_layout()
        plt.savefig(sanitize_filename(title) + ".png", dpi=300)
        plt.close()
        return

    # Normal case
    cdf = np.arange(1, len(samples) + 1) / len(samples)
    plt.figure(figsize=(10, 6))
    plt.plot(sorted_samples, cdf, "b-", lw=2)

    plt.title(title)
    plt.xlabel("Mass [kg]")
    plt.ylabel("Cumulative probability")
    plt.grid(True, alpha=0.3)
    plt.tight_layout()
    plt.savefig(sanitize_filename(title) + ".png", dpi=300)
    plt.close()
