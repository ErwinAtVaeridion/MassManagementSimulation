def to_float(x, default=0.0):
    """Change x to float, returning default if NaN/None/''."""
    try:
        if pd.isna(x):
            return default
        if isinstance(x, str):
            s = x.strip().replace("%", "")
            if s == "":
                return default
            return float(s)
        return float(x)
    except Exception:
        return default

def sanitize_filename(name: str) -> str:
    """Create safe filenames from titles/group names."""
    name = (name or "").strip()
    name = re.sub(r"[^\w\s\-._]+", "", name)  # '+' outside the class
    name = re.sub(r"\s+", "_", name)
    return name[:120]

