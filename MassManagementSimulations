    # -- 5) Compile with MiKTeX (XeLaTeX), not on PATH -> point to exact executable
    def find_miktex_xelatex() -> str:
        candidates = [
            r"C:\Program Files\MiKTeX\miktex\bin\x64\xelatex.exe",
            r"C:\Program Files\MiKTeX\bin\x64\xelatex.exe",
            r"C:\Program Files\MiKTeX\miktex\bin\xelatex.exe",
            r"C:\Program Files\MiKTeX\bin\xelatex.exe",
        ]
        for exe in candidates:
            if Path(exe).exists():
                return exe
        raise FileNotFoundError(
            "MiKTeX 'xelatex.exe' not found under 'C:\\Program Files\\MiKTeX'.\n"
            "Please install MiKTeX or adjust the candidate paths in find_miktex_xelatex()."
        )

    xelatex = find_miktex_xelatex()
    env = os.environ.copy()
    env["PATH"] = str(Path(xelatex).parent) + os.pathsep + env.get("PATH", "")

    def run_xelatex(pass_idx: int) -> None:
        cmd = [xelatex, "-interaction=nonstopmode", "-halt-on-error", "report.tex"]
        print(f"Running xelatex pass {pass_idx}: {xelatex}")
        proc = subprocess.run(
            cmd,
            cwd=str(PDF_TEX_DIR),
            env=env,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            text=True,
            encoding="utf-8",
            errors="replace",
        )
        # Do not write LaTeX compiler output to disk; keep in-memory only.
        print(f"xelatex pass {pass_idx} completed (compiler output captured).")
        if proc.returncode != 0:
            tail = "\n".join((proc.stdout or "").splitlines()[-80:])
            raise RuntimeError(
                f"xelatex failed on pass {pass_idx}.\n"
                f"--- Last compiler lines ---\n{tail}\n"
                f"--- End last lines ---\n"
            )

    # Two passes for references
