# Aircraft-level CDF
# ------------------------------------------------------------
def plot_aircraft_cdf(samples, title):

    sorted_samples = np.sort(samples)
    cdf = np.arange(1, len(samples) + 1) / len(samples)

    plt.figure(figsize=(10, 6))
    plt.plot(sorted_samples, cdf, "b-", lw=2)

    # Percentiles P25,50,75,95
    desired_percentiles = [25, 50, 75, 95]
    perc_values = np.percentile(samples, desired_percentiles)

    # Draw P lines
    colors = ["C0", "C1", "C2", "C3"]
    for p, v, col in zip(desired_percentiles, perc_values, colors):
        y = p / 100.0
        plt.axvline(v, color=col, linestyle="--", lw=1)
        plt.axhline(y, color=col, linestyle=":", lw=1)
        plt.plot(v, y, marker="o", color=col)
        plt.annotate(f"P{p}: {v:.1f} kg",
                     xy=(v, y),
                     xytext=(5, 5),
                     textcoords="offset points",
                     fontsize=9,
                     color=col)

    # Confidence level line
    v_des = np.percentile(samples, CONFIDENCE_LEVEL)
    y_des = CONFIDENCE_LEVEL / 100.0
    plt.axvline(v_des, color="k", linestyle="-", lw=1)
    plt.axhline(y_des, color="k", linestyle="-", lw=1)
    plt.plot(v_des, y_des, marker="s", color="k")
    plt.annotate(
        f"P({int(CONFIDENCE_LEVEL)}): {v_des:.1f} kg",
        xy=(v_des, y_des),
        xytext=(-10, 20),
        textcoords="offset points",
        fontsize=10,
        color="k",
        bbox=dict(boxstyle="round", facecolor="white", alpha=0.6)
    )

    # Target mass probability
    prob_aircraft_mass_target = np.mean(samples <= OEM_TARGET)
    plt.axvline(OEM_TARGET, color="k", linestyle="-", lw=1.5)
    plt.axhline(prob_aircraft_mass_target, color="k", linestyle="--", lw=1.0)
    plt.plot(OEM_TARGET, prob_aircraft_mass_target, marker="s", color="k")
    plt.annotate(
        f"P(Mass ≤ {OEM_TARGET:.0f} kg) = {prob_aircraft_mass_target:.4f}",
        xy=(OEM_TARGET, prob_aircraft_mass_target),
        xytext=(10, -20),
        textcoords="offset points",
        fontsize=10,
        color="k",
        bbox=dict(boxstyle="round", facecolor="white", alpha=0.6)
    )

    # Text box summary (as in original code)
    txt_lines = [
        f"P{p}: {val:.1f} kg"
        for p, val in zip(desired_percentiles, perc_values)
    ]
    txt_lines.append(f"P{int(CONFIDENCE_LEVEL)}: {v_des:.1f} kg")
    txt_lines.append(f"Target Mass {int(OEM_TARGET)} kg -> P = {prob_aircraft_mass_target:.4f}")
    textbox_text = "\n".join(txt_lines)

    props = dict(boxstyle="round", facecolor="wheat", alpha=0.85)
    plt.gca().text(
        0.02, 0.98, textbox_text,
        transform=plt.gca().transAxes,
        fontsize=10,
        verticalalignment='top',
        bbox=props
    )

    plt.title(title)
    plt.xlabel("Mass [kg]")
    plt.ylabel("Cumulative probability")
    plt.grid(True, alpha=0.3)
    plt.tight_layout()

    fname = sanitize_filename(title) + ".png"
    plt.savefig(fname, dpi=300)
    plt.close()


