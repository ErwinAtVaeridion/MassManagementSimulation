            total_mga       = sum(it.get("mga",       0.0) for it in items)
            total_predicted = sum(it.get("predicted", 0.0) for it in items)
            total_pos_unc   = sum(it.get("pos_unc",   0.0) for it in items)
            total_neg_unc   = sum(it.get("neg_unc",   0.0) for it in items)

            # L2 summary row comes first (double rule underneath via extra \hline)
            summary_row = (
                r"\textbf{" + tex_escape(f"{l2_name}") + r"} & "
                + r"\textbf{" + fmt_kg(total_basic)     + r"} & "
                + r"\textbf{" + fmt_kg(total_mga)       + r"} & "
                + r"\textbf{" + fmt_kg(total_predicted) + r"} & "
                + r"\textbf{" + fmt_kg(total_pos_unc)   + r"} & "
                + r"\textbf{" + fmt_kg(total_neg_unc)   + r"} \\ \hline"
            )
            rows.append(summary_row)

            # L3 detail rows follow, sorted alphabetically
            for it in sorted(items, key=lambda x: x.get("name", "")):
