            r"\textbf{Title} & "
            r"\textbf{Basic [kg]} & "
            r"\textbf{MGA [kg]} & "
            r"\textbf{Predicted [kg]} & "
            r"\textbf{+Unc [kg]} & "
            r"\textbf{-Unc [kg]} " + r"\\" + " \n"
            r"\hline"
        )

