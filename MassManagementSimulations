# -----------------------------
# PERT distribution core
# -----------------------------
def make_pert_params(predicted_mass, neg, pos, weight=4.0):
    """
    Build parameters for a PERT-like Beta on [a,b] with mode m=predicted_mass.
      a = max(predicted_mass + neg, 0)  # clamp to zero (physical sanity)
      b = max(predicted_mass + pos, 0)
    If a == b -> degenerate (fixed) value.
    Returns:
      - (None, a, b, m) if degenerate (fixed)
      - (a, b, alpha, beta_param, m) otherwise
    """
    a = predicted_mass + neg
    b = predicted_mass + pos

    # Physical constraint: mass cannot be negative
    a = max(a, 0.0)
    b = max(b, 0.0)

    # Degenerate -> fixed value
    if np.isclose(a, b):
        m = a
        return (None, a, b, m)

    # Keep mode inside [a,b]
    m = np.clip(predicted_mass, a, b)
    scale = b - a
    alpha = 1.0 + weight * (m - a) / scale
    beta_param = 1.0 + weight * (b - m) / scale
    return (a, b, alpha, beta_param, m)

def sample_pert(params, size):
    """Draw PERT samples for given params tuple."""
    if params[0] is None:  # fixed value
        return np.full(size, params[-1])
    a, b, alpha, beta_param, _ = params
    u = RNG.beta(alpha, beta_param, size=size)
    return a + u * (b - a)

