def make_group_tabularx_tex(group_name: str, items: list[dict]) -> str:
    r"""
    Render a tabularx table constrained to \textwidth.

    Expected keys per item:
      - name: str
      - basic: float
      - mga: float
      - predicted: float
      - pos_unc: float
      - neg_unc: float

    Requires LaTeX packages:
      \usepackage{tabularx}
      \usepackage{booktabs}
      \usepackage{makecell}
    """

    caption_text = tex_escape(f"L2 components for {group_name}")

    header = (
        r"\toprule" + "\n"
        r"\makecell[l]{\textbf{Title}} & "
        r"\makecell[r]{\textbf{Basic Mass [kg]}} & "
        r"\makecell[r]{\textbf{MGA [kg]}} & "
        r"\makecell[r]{\textbf{Predicted [kg]}} & "
        r"\makecell[r]{\textbf{+Unc [kg]}} & "
        r"\makecell[r]{\textbf{-Unc [kg]}} "
        + r"\\" + "\n"
        r"\midrule"
    )

    rows = []
    for it in sorted(items, key=lambda x: x.get("name", "")):
        title     = tex_escape(it.get("name", ""))
        basic     = fmt_kg(it.get("basic", 0.0))
        mga       = fmt_kg(it.get("mga", 0.0))
        predicted = fmt_kg(it.get("predicted", 0.0))
        up        = fmt_kg(it.get("pos_unc", 0.0))
        dn        = fmt_kg(it.get("neg_unc", 0.0))

        row = f"{title} & {basic} & {mga} & {predicted} & {up} & {dn} "
        rows.append(row + r"\\" + "\n")

    body = "\n".join(rows) if rows else (
        r"\multicolumn{6}{l}{\emph{No items in this group.}} " + r"\\" + "\n"
    )

    table = (
        r"\begin{table}[H]" + "\n"
        r"\centering" + "\n"
        r"\caption{" + caption_text + r"}" + "\n"
        r"\begin{tabularx}{\textwidth}{Xrrrrr}" + "\n"
        + header + "\n"
        + body +
        r"\bottomrule" + "\n"
        r"\end{tabularx}" + "\n"
        r"\end{table}"
    )

    return table

