def find_group_name_around(df, i, max_lookahead=6):
    """
    From a 'Level 1B' row index i, try to locate a group name in Column B (col=1)
    either in the same row or within the next few rows.
    """
    b0 = df.iloc[i, 1]
    if isinstance(b0, str) and b0.strip() in EXPECTED_GROUPS:
        return b0.strip()

    for k in range(1, max_lookahead + 1):
        if (i + k) >= len(df):
            break
        b = df.iloc[i + k, 1]
        if isinstance(b, str) and b.strip() in EXPECTED_GROUPS:
            return b.strip()
    return None


# -----------------------------
# Extract L2 components with corrected mapping
# -----------------------------
# dynamically locate the columns we care about by scanning
# the first few rows of the sheet.  The idea is that the headers may
# move around or the order may change; we only care that some cell in
# the first 15 rows contains a recognizable keyword.

# list of header names we expect exactly; the search is now
# strict (case‑insensitive equality) rather than substring matching.
# the five required columns are:
#   Basic Mass [kg]
#   MGA [kg]
#   Predicted Mass [kg]
#   Uncertainty (+) [kg]
#   Uncertainty (-) [kg]
# any other columns (e.g. maturity, novelty, MGA [%]) are ignored by
# this scan.
search_terms = {
    "basic": ["basic mass [kg]"],
    "mga": ["mga [kg]"],
    "predicted": ["predicted mass [kg]"],
    "pos_unc": ["uncertainty (+) [kg]"],
    "neg_unc": ["uncertainty (-) [kg]"],
}

# default column indices if we fail to detect anything; matches the
# original hard‑coded layout (C=2..G=6)
default_cols = {"basic": 2, "mga": 3, "predicted": 4,
                "pos_unc": 5, "neg_unc": 6}

# walk the first few rows looking for our keywords
col_map = {k: None for k in search_terms}
max_header_rows = min(len(df), 15)
for i in range(max_header_rows):
    for j, cell in enumerate(df.iloc[i]):
        if not isinstance(cell, str):
            continue
        lc = cell.strip().lower()
        for key, terms in search_terms.items():
            if col_map[key] is not None:
                # already found
                continue
            for term in terms:
                # match on equality rather than substring
                if lc == term:
                    col_map[key] = j
                    break
            if col_map[key] is not None:
                break

# fall back to defaults if any column was not identified
for key, idx in col_map.items():
    if idx is None:
        col_map[key] = default_cols[key]

# report what we ended up using so that it's easier to troubleshoot
print(f"Detected column indices: {col_map} (defaults used for missing headers)")

components = []  # dicts: {group, name, basic, mga, predicted, pos_unc, neg_unc}

current_group = None
for i in range(len(df)):
    a = df.iloc[i, 0]

    # Detect Level 1B group headers
    if isinstance(a, str) and a.strip() == "Level 1B":
        g = find_group_name_around(df, i)
        current_group = g or current_group
        continue

    # Process Level 2 rows
    if isinstance(a, str) and a.strip() == "Level 2":
        name = df.iloc[i, 1]
        if not isinstance(name, str) or name.strip() == "":
            continue

        # -----------------------------
        # CORRECTED COLUMN MAPPING
        # -----------------------------
        basic = to_float(df.iloc[i, col_map["basic"]], 0.0)
        mga = to_float(df.iloc[i, col_map["mga"]], 0.0)
        predicted = to_float(df.iloc[i, col_map["predicted"]], 0.0)
        pos_unc = to_float(df.iloc[i, col_map["pos_unc"]], 0.0)
        neg_unc = to_float(df.iloc[i, col_map["neg_unc"]], 0.0)

        components.append({
            "group": current_group if current_group else "Unknown",
            "name": name.strip(),
            "basic": basic,
            "mga": mga,
            "predicted": predicted,
            "pos_unc": abs(pos_unc),
            "neg_unc": -abs(neg_unc),
        })

