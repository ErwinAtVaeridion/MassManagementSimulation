                basic = fmt_kg(it.get("basic", 0.0))
                mga = fmt_kg(it.get("mga", 0.0))
                predicted = fmt_kg(it.get("predicted", 0.0))
                up = fmt_kg(it.get("pos_unc", 0.0))
                dn = fmt_kg(it.get("neg_unc", 0.0))  # stays signed (typically negative)
                row = f"{title} & {basic} & {mga} & {predicted} & {up} & {dn} \\\\ \\hline"
                rows.append(row)
        else:
            # Keep the frame and show a single info row spanning all columns
            rows.append(r"\multicolumn{6}{|l|}{\emph{No L3 components for this L2 system.}} \\ \hline")

        body = "\n".join(rows)

        # Assemble the full table environment (no booktabs; full borders)
        table = (
            r"\begin{table}[H]" + "\n"
            r"\centering" + "\n"
            r"\caption{" + caption_text + r"}" + "\n"
            r"\begin{tabularx}{\textwidth}{|X|r|r|r|r|r|}" + "\n"
            + header + "\n"
            + body + "\n"
            r"\end{tabularx}" + "\n"
            r"\end{table}"
        )
