# -- 2) Helpers for LaTeX text  (replace your current _LATEX_REPLACEMENTS with this) --
_LATEX_REPLACEMENTS = [
    ("\\", r"\textbackslash{}"),
    ("{", r"\{"), ("}", r"\}"),
    ("$", r"\$"), ("&", r"\&"), ("#", r"\#"),
    ("_", r"\_"),  # <-- underscore itself, not the sequence "\_"
    ("%", r"\%"),
    ("~", r"\textasciitilde{}"),
    ("^", r"\textasciicircum{}"),
]
def tex_escape(s: str) -> str:
    if s is None:
        return ""
    # Preserve comparison symbols as LaTeX math after escaping other characters.
    if s is None:
        return ""
    out = str(s)
    # Temporarily protect unicode comparison symbols with tokens that won't be escaped
    out = out.replace("≤", "<<<LE>>>").replace("≥", "<<<GE>>>")

    # Apply replacements except underscore (handle underscore last to avoid clobbering tokens)
    for a, b in _LATEX_REPLACEMENTS:
        if a == "_":
            continue
        out = out.replace(a, b)

    # Reinsert as math constructs so LaTeX prints the symbols reliably under XeLaTeX
    out = out.replace("<<<LE>>>", r"$\\leq$")
    out = out.replace("<<<GE>>>", r"$\\geq$")

    # Escape underscore as the final step
    out = out.replace("_", r"\\_")
    return out


def sanitize_for_verbatim(s: str) -> str:
    if s is None:
        return ""
    # Keep unicode comparison symbols; normalize other cosmetic characters
    return (s
        .replace("✓", "[OK]").replace("✔", "[OK]")
        .replace("✗", "[FAIL]").replace("✘", "[FAIL]")
        .replace("—", "-").replace("–", "-")
    )

def fmt_kg(x, nd=1):
    try: return f"{float(x):.{nd}f}"
    except: return ""

def fmt_rdf(x):
    try:
        xv = float(x)
        return f"{int(xv)}" if abs(xv - int(xv)) < 1e-9 else f"{xv:.3f}"
    except: return ""


# convert integer to ordinal string (1 -> '1st', 2 -> '2nd', etc.)
def ordinal(n: int) -> str:
    suffix = 'th'
    if not (10 <= n % 100 <= 20):
        suffix = {1: 'st', 2: 'nd', 3: 'rd'}.get(n % 10, 'th')
    return f"{n}{suffix}"

