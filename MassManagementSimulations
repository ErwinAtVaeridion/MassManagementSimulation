# Base output folder
results_base = r"C:\development\CodeRepository\MassManagement\SimulationResults"

# Create timestamped results folder
timestamp = datetime.now().strftime("%Y-%m-%d_%H-%M-%S")
results_folder = os.path.join(results_base, f"Results_{timestamp}")
os.makedirs(results_folder, exist_ok=True)

print(f"\nSaving all plots and results to:\n  {results_folder}\n")

# ------------------------------------------------------------
# 1) Move all PNG images generated in the working directory
# ------------------------------------------------------------
png_files = glob.glob("*.png")
for f in png_files:
    dest = os.path.join(results_folder, f)
    try:
        os.replace(f, dest)  # atomic move if possible
    except Exception:
        import shutil
        shutil.move(f, dest)
print(f"Saved {len(png_files)} image files.")

# ------------------------------------------------------------
# 2) Build the exact text summary (same as console output)
# ------------------------------------------------------------
lines = []
lines.append("=== Aircraft-Level Results ===")
for p, v in zip(pcts, vals):  # pcts = [25, 50, 75, 90, 95]; vals computed earlier
    lines.append(f"  P{p}: {v:.1f} kg")
lines.append(f"  P{int(CONFIDENCE_LEVEL)}: {v_conf_air:.1f} kg")
lines.append("")
lines.append(f"  Probability(Mass ≤ Target {OEM_TARGET:.1f} kg): {prob_target:.6f}")
lines.append(f"  Probability(Mass ≤ EIS    {ENTRY_INTO_SERVICE_MASS:.1f} kg): {prob_eis:.6f}")
lines.append("")
lines.append("Conclusion:")
if mass_diff > 0:
    lines.append("  ✔ Target mass CAN be achieved at the required confidence level.")
    lines.append(f"  Available margin: {mass_diff:.1f} kg")
else:
    lines.append("  ✘ Target mass CANNOT be achieved at the required confidence level.")
    lines.append(f"  Required cumulative L2 mass reduction: {-mass_diff:.1f} kg")

# Optional context lines (helpful metadata)
lines.append("")
lines.append(f"Sheet used: {newest_sheet}")
lines.append(f"Saved at:   {timestamp}")

summary_text = "\n".join(lines)

# Print to console as well (keeps behavior consistent)
print("\n" + summary_text + "\n")

# ------------------------------------------------------------
# 3) Write summary to UTF-8 text file
# ------------------------------------------------------------
summary_path = os.path.join(results_folder, "Simulation_Results.txt")
with open(summary_path, "w", encoding="utf-8") as txt:
    txt.write(summary_text + "\n")

print("Text summary saved.")
print("All simulation results saved successfully.\n")