def find_group_name_around(df, i, max_lookahead=6):
    """
    From a 'Level 1B' row index i, try to locate a group name in Column B (col=1)
    either in the same row or within the next few rows.
    """
    b0 = df.iloc[i, 1]
    if isinstance(b0, str) and b0.strip() in EXPECTED_GROUPS:
        return b0.strip()

    for k in range(1, max_lookahead + 1):
        if (i + k) >= len(df):
            break
        b = df.iloc[i + k, 1]
        if isinstance(b, str) and b.strip() in EXPECTED_GROUPS:
            return b.strip()
    return None


