        basic = to_float(df.iloc[i, 2], 0.0)     # Column C → Basic Mass
        mga   = to_float(df.iloc[i, 3], 0.0)     # Column D → MGA
        pos_unc = to_float(df.iloc[i, 5], 0.0)   # Column F → Positive uncertainty
        neg_unc = to_float(df.iloc[i, 6], 0.0)   # Column G → Negative uncertainty
        rdf     = to_float(df.iloc[i, 7], 1.0)   # Column H → RDF

        # Mass target (as in original logic)
        if rdf == 0:
            rdf = 1.0
        target = (basic + mga) * rdf

        components.append({
            "group": current_group if current_group else "Unknown",
            "name": name.strip(),
            "basic": basic,
            "mga": mga,
            "pos_unc": abs(pos_unc),
            "neg_unc": -abs(neg_unc),
            "rdf": rdf,
            "target": target
        })

